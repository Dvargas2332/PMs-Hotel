  "type": "module",
  "license": "UNLICENSED",
  "prisma": {
    "schema": "prisma/schema.prisma"
  },
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc -p tsconfig.json",
    "prestart": "npm run build",
    "start": "node dist/server.js",
    "postinstall": "prisma generate",
    "prisma:format": "prisma format",
