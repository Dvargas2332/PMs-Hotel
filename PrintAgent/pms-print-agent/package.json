{
  "name": "pms-print-agent",
  "version": "0.1.0",
  "private": true,
  "description": "Local printing agent for PMS (Windows). Exposes a local API to list printers and print jobs.",
  "main": "src/index.js",
  "bin": "src/index.js",
  "scripts": {
    "dev": "node src/index.js",
    "start": "node src/index.js",
    "build:exe": "pkg . --targets node18-win-x64 --output dist/pms-print-agent.exe"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "express": "^4.19.2"
  },
  "devDependencies": {
    "dotenv": "^16.4.5",
    "pkg": "^5.8.1"
  },
  "pkg": {
    "scripts": [
      "src/**/*.js"
    ]
  }
}
