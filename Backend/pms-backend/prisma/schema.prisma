// prisma/schema.prisma

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ===== Enums =====
enum Role {
  ADMIN
  MANAGER
  RECEPTION
}

enum RoomStatus {
  AVAILABLE
  OCCUPIED
  CLEANING
  BLOCKED
}

enum ReservationStatus {
  PENDING
  CONFIRMED
  CHECKED_IN
  CHECKED_OUT
  CANCELED
}

enum RestaurantOrderStatus {
  OPEN
  CLOSED
  PAID
}

enum InvoiceStatus {
  DRAFT
  ISSUED
  CANCELED
  REFUNDED
}

enum BookingSource {
  DIRECT
  OTA
  MANUAL
}

// Cierres de caja / auditorias
enum CashAuditModule {
  FRONTDESK
  RESTAURANT
}

// ==== Restaurante ====

model RestaurantConfig {
  hotelId        String  @id
  kitchenPrinter String?
  barPrinter     String?
  updatedAt      DateTime @updatedAt

  hotel Hotel @relation(fields: [hotelId], references: [id], onDelete: Cascade)
}

model RestaurantPrintJob {
  id             String   @id @default(cuid())
  hotelId        String
  sectionId      String?
  tableId        String
  items          Json
  note           String?
  covers         Int?
  kitchenPrinter String?
  barPrinter     String?
  userId         String?
  createdAt      DateTime @default(now())

  hotel Hotel @relation(fields: [hotelId], references: [id], onDelete: Cascade)

  @@index([hotelId])
}

model RestaurantClose {
  id             String   @id @default(cuid())
  hotelId        String
  turno          String
  totals         Json
  payments       Json
  breakdown      Json?
  note           String?
  createdAt      DateTime @default(now())
  userId         String?

  hotel Hotel @relation(fields: [hotelId], references: [id], onDelete: Cascade)

  @@index([hotelId])
}

model RestaurantOrder {
  id               String                  @id @default(cuid())
  hotelId          String
  sectionId        String?
  tableId          String
  waiterId         String?
  status           RestaurantOrderStatus   @default(OPEN)
  note             String?
  covers           Int?
  total            Decimal                 @default(0) @db.Decimal(12, 2)
  tip10            Decimal                 @default(0) @db.Decimal(12, 2)
  paymentBreakdown Json?
  createdAt        DateTime                @default(now())
  updatedAt        DateTime                @updatedAt

  items RestaurantOrderItem[]

  hotel Hotel @relation(fields: [hotelId], references: [id], onDelete: Cascade)

  @@index([hotelId])
  @@index([hotelId, tableId, status])
}

model RestaurantOrderItem {
  id        String   @id @default(cuid())
  orderId   String
  itemId    String
  name      String
  category  String?
  price     Decimal  @db.Decimal(12, 2)
  qty       Int

  order RestaurantOrder @relation(fields: [orderId], references: [id], onDelete: Cascade)
}

model RestaurantSection {
  id      String @id
  hotelId String
  name    String

  tables RestaurantTable[]
  menu   RestaurantMenuItem[]

  hotel Hotel @relation(fields: [hotelId], references: [id], onDelete: Cascade)

  @@unique([hotelId, id])
  @@index([hotelId])
}

model RestaurantTable {
  id        String @id
  sectionId String
  name      String
  seats     Int    @default(2)

  section RestaurantSection @relation(fields: [sectionId], references: [id], onDelete: Cascade)

  @@index([sectionId])
}

model RestaurantMenuItem {
  id        String   @id @default(cuid())
  hotelId   String
  sectionId String?
  name      String
  category  String?
  price     Decimal  @default(0) @db.Decimal(12, 2)
  active    Boolean  @default(true)
  createdAt DateTime @default(now())

  section RestaurantSection? @relation(fields: [sectionId], references: [id], onDelete: Cascade)
  hotel   Hotel              @relation(fields: [hotelId], references: [id], onDelete: Cascade)

  @@index([hotelId])
  @@index([sectionId])
}

// ⬇️ NUEVO
model Hotel {
  id        String   @id @default(cuid())
  name      String
  currency  String   @default("CRC")
  fxBuy     Decimal  @default(0) @db.Decimal(12, 4)
  fxSell    Decimal  @default(0) @db.Decimal(12, 4)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  rooms           Room[]
  roomTypes       RoomType[]
  reservations    Reservation[]
  users           User[]
  roles           AppRole[]
  rolePerms       RolePermission[]
  invoices        Invoice[]
  guests          Guest[]
  payments        Payment[]
  auditLogs       AuditLog[]
  invoiceItems    InvoiceItem[]
  reports         Report[]
  advanceDeposits AdvanceDeposit[]
  creditNotes     CreditNote[]
  cashAudits      CashAudit[]
  restaurantConfig   RestaurantConfig?
  restaurantPrintJobs RestaurantPrintJob[]
  restaurantCloses    RestaurantClose[]
  restaurantOrders    RestaurantOrder[]
  restaurantSections  RestaurantSection[]
  restaurantMenuItems RestaurantMenuItem[]
}

// ===== Models =====
model User {
  id           String        @id @default(cuid())
  email        String        @unique
  name         String?
  password     String
  role         Role          @default(RECEPTION)
  hotelId      String
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  reservations Reservation[]

  hotel Hotel @relation(fields: [hotelId], references: [id], onDelete: Cascade)

  @@index([hotelId])
}

model Guest {
  id           String        @id @default(cuid())
  firstName    String
  lastName     String
  email        String?
  phone        String?
  state        String?
  idType       String?
  idNumber     String?
  legalName        String?
  managerName      String?
  economicActivity String?
  emailAlt1        String?
  emailAlt2        String?
  country      String?
  city         String?
  address      String?
  company      String?
  notes        String?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  reservations    Reservation[]
  invoices        Invoice[]
  advanceDeposits AdvanceDeposit[]
  creditNotes     CreditNote[]
  hotelId         String
  hotel           Hotel @relation(fields: [hotelId], references: [id], onDelete: Cascade)

  @@unique([hotelId, email])
  @@index([hotelId])
}

model Room {
  id        String     @id @default(cuid())
  number    String
  type      String
  status    RoomStatus @default(AVAILABLE)
  archived  Boolean    @default(false)
  notes     String?
  baseRate  Decimal    @default(0) @db.Decimal(10, 2)
  currency  String     @default("CRC")
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  hotelId String
  hotel   Hotel  @relation(fields: [hotelId], references: [id], onDelete: Cascade)

  reservations Reservation[]
  days         RoomDay[]

  @@unique([hotelId, number])
  @@index([hotelId])
}

model RoomType {
  id        String   @id
  name      String
  beds      String?
  hotelId   String
  hotel     Hotel    @relation(fields: [hotelId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([hotelId, id])
  @@index([hotelId])
}

model Reservation {
  id         String            @id @default(cuid())
  code       String            @unique
  rooming    String?
  otaCode    String?
  roomId     String
  guestId    String
  userId     String?
  checkIn    DateTime
  checkOut   DateTime
  adults     Int               @default(2)
  children   Int               @default(0)
  status     ReservationStatus @default(CONFIRMED)
  source     BookingSource?
  createdAt  DateTime          @default(now())
  updatedAt  DateTime          @updatedAt
  auditTrail Json?

  room  Room  @relation(fields: [roomId], references: [id])
  guest Guest @relation(fields: [guestId], references: [id])
  user  User? @relation(fields: [userId], references: [id])

  /// Relación 1–1 con Invoice (lado SIN FK)
  invoice          Invoice?         @relation("ReservationInvoice")
  advanceDeposits  AdvanceDeposit[]

  days RoomDay[]

  hotelId String
  hotel   Hotel  @relation(fields: [hotelId], references: [id], onDelete: Cascade)

  @@index([roomId])
  @@index([guestId])
  @@index([hotelId])
}

model RoomDay {
  id            String   @id @default(cuid())
  date          DateTime
  roomId        String
  reservationId String?

  status RoomStatus @default(AVAILABLE)
  rate   Decimal    @default(0) @db.Decimal(12, 2)
  notes  String?

  room        Room         @relation(fields: [roomId], references: [id])
  reservation Reservation? @relation(fields: [reservationId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([roomId, date])
  @@index([reservationId])
}

model AuditLog {
  id        String   @id @default(cuid())
  actorId   String?
  action    String
  entity    String
  entityId  String
  reason    String?
  payload   Json?
  createdAt DateTime @default(now())
  hotelId   String
  hotel     Hotel @relation(fields: [hotelId], references: [id], onDelete: Cascade)

  @@index([hotelId])
}

model Country {
  code    String   @id
  name    String
  regions Region[]
  cities  City[]
}

model Region {
  id          String  @id @default(cuid())
  code        String?
  name        String
  countryCode String
  country     Country @relation(fields: [countryCode], references: [code], onDelete: Cascade)
  cities      City[]

  @@index([countryCode])
}

model City {
  id          String  @id @default(cuid())
  name        String
  countryCode String
  regionId    String?
  country     Country @relation(fields: [countryCode], references: [code], onDelete: Cascade)
  region      Region? @relation(fields: [regionId], references: [id], onDelete: SetNull)

  @@index([countryCode])
  @@index([regionId])
}

model Report {
  id          String   @id @default(cuid())
  hotelId     String
  title       String?
  category    String?
  type        String?
  periodStart DateTime?
  periodEnd   DateTime?
  filters     Json?
  payload     Json?
  createdAt   DateTime @default(now())
  createdBy   String?

  hotel Hotel @relation(fields: [hotelId], references: [id], onDelete: Cascade)

  @@index([hotelId])
  @@index([hotelId, periodStart, periodEnd])
}

model Invoice {
  id            String        @id @default(cuid())
  number        String        @unique
  reservationId String        @unique
  guestId       String
  total         Decimal       @default(0) @db.Decimal(12, 2)
  currency      String        @default("CRC")
  status        InvoiceStatus @default(DRAFT)
  eInvoice      Json?
  auditTrail    Json?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  hotelId       String

  /// Lado CON FK (1–1). Todo en una línea para evitar parseos raros:
  reservation Reservation   @relation("ReservationInvoice", fields: [reservationId], references: [id], onDelete: Cascade)
  guest       Guest         @relation(fields: [guestId], references: [id])
  items       InvoiceItem[]
  payments    Payment[]
  creditNotes CreditNote[]
  hotel       Hotel         @relation(fields: [hotelId], references: [id], onDelete: Cascade)

  @@index([guestId])
  @@index([hotelId])
}

model InvoiceItem {
  id          String   @id @default(cuid())
  invoiceId   String
  description String
  quantity    Int      @default(1)
  unitPrice   Decimal  @default(0) @db.Decimal(12, 2)
  total       Decimal  @default(0) @db.Decimal(12, 2)
  createdAt   DateTime @default(now())
  hotelId     String

  invoice Invoice @relation(fields: [invoiceId], references: [id])
  hotel   Hotel   @relation(fields: [hotelId], references: [id], onDelete: Cascade)

  @@index([invoiceId])
  @@index([hotelId])
}

model Payment {
  id        String   @id @default(cuid())
  invoiceId String
  method    String
  amount    Decimal  @default(0) @db.Decimal(12, 2)
  createdAt DateTime @default(now())
  hotelId   String

  invoice Invoice @relation(fields: [invoiceId], references: [id])
  hotel   Hotel   @relation(fields: [hotelId], references: [id], onDelete: Cascade)

  @@index([invoiceId])
  @@index([hotelId])
}

model AdvanceDeposit {
  id             String   @id @default(cuid())
  reservationId  String?
  guestId        String?
  amount         Decimal  @default(0) @db.Decimal(12, 2)
  currency       String   @default("CRC")
  note           String?
  appliedInvoice String?
  createdAt      DateTime @default(now())
  hotelId        String

  reservation Reservation? @relation(fields: [reservationId], references: [id])
  guest       Guest?       @relation(fields: [guestId], references: [id])
  hotel       Hotel        @relation(fields: [hotelId], references: [id], onDelete: Cascade)

  @@index([hotelId])
  @@index([reservationId])
  @@index([guestId])
}

model CreditNote {
  id          String   @id @default(cuid())
  invoiceId   String?
  guestId     String?
  amount      Decimal  @default(0) @db.Decimal(12, 2)
  currency    String   @default("CRC")
  reason      String?
  createdAt   DateTime @default(now())
  hotelId     String

  invoice Invoice? @relation(fields: [invoiceId], references: [id])
  guest   Guest?   @relation(fields: [guestId], references: [id])
  hotel   Hotel    @relation(fields: [hotelId], references: [id], onDelete: Cascade)

  @@index([hotelId])
  @@index([invoiceId])
  @@index([guestId])
}

model CashAudit {
  id          String          @id @default(cuid())
  hotelId     String
  module      CashAuditModule
  openedAt    DateTime?
  closedAt    DateTime? @default(now())
  totals      Json?
  details     Json?
  note        String?
  createdById String?
  createdAt   DateTime @default(now())

  hotel Hotel @relation(fields: [hotelId], references: [id], onDelete: Cascade)

  @@index([hotelId])
  @@index([hotelId, module, createdAt])
}

model AppRole {
  id          String   @id
  name        String
  description String?
  hotelId     String

  hotel       Hotel            @relation(fields: [hotelId], references: [id], onDelete: Cascade)
  permissions RolePermission[]

  @@unique([hotelId, id])
  @@index([hotelId])
}

model Permission {
  id          String   @id
  description String?
  permissions RolePermission[]
}

model RolePermission {
  id           String      @id @default(cuid())
  roleId       String
  permissionId String
  hotelId      String

  role       AppRole    @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)
  hotel      Hotel      @relation(fields: [hotelId], references: [id], onDelete: Cascade)

  @@unique([hotelId, roleId, permissionId])
  @@index([hotelId])
}
