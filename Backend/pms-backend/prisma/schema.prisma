// prisma/schema.prisma

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ===== Enums =====
enum Role {
  ADMIN
  MANAGER
  RECEPTION
}

enum RoomStatus {
  AVAILABLE
  OCCUPIED
  CLEANING
  BLOCKED
}

enum ReservationStatus {
  PENDING
  CONFIRMED
  CHECKED_IN
  CHECKED_OUT
  CANCELED
}

enum RestaurantOrderStatus {
  OPEN
  CLOSED
  PAID
}

enum RestaurantKdsArea {
  KITCHEN
  BAR
}

enum RestaurantOrderItemStatus {
  NEW
  IN_KITCHEN
  READY
  SERVED
}

enum RestaurantStaffRole {
  CASHIER
  WAITER
}

// Restaurant inventory units
// Stored as String to keep backward/forward compatibility with UI.

enum InvoiceStatus {
  DRAFT
  ISSUED
  CANCELED
  REFUNDED
}

enum EInvoicingDocType {
  FE // Factura Electrónica
  TE // Tiquete Electrónico
}

enum EInvoicingDocStatus {
  DRAFT
  SIGNED
  SENT
  ACCEPTED
  REJECTED
  CANCELED
  CONTINGENCY
}

enum EInvoicingAckType {
  HACIENDA_RECEIPT
  HACIENDA_STATUS
  RECEIVER_MESSAGE
  OTHER
}

enum EInvoicingAckStatus {
  RECEIVED
  ACCEPTED
  REJECTED
  ERROR
}

enum BookingSource {
  DIRECT
  OTA
  MANUAL
}

// Cierres de caja / auditorias
enum CashAuditModule {
  FRONTDESK
  RESTAURANT
}

// ==== Restaurante ====

model RestaurantConfig {
  hotelId        String   @id
  kitchenPrinter String?
  barPrinter     String?
  cashierPrinter String?
  taxes          Json?
  payments       Json?
  general        Json?
  billing        Json?
  printing       Json?
  updatedAt      DateTime @updatedAt

  hotel Hotel @relation(fields: [hotelId], references: [id], onDelete: Cascade)
}

model RestaurantPrintJob {
  id             String   @id @default(cuid())
  hotelId        String
  orderId        String?
  sectionId      String?
  tableId        String
  type           String?
  docType        String?
  formId         String?
  header         String?
  footer         String?
  items          Json
  note           String?
  covers         Int?
  kitchenPrinter String?
  barPrinter     String?
  cashierPrinter String?
  paperType      String?
  userId         String?
  createdAt      DateTime @default(now())

  hotel Hotel @relation(fields: [hotelId], references: [id], onDelete: Cascade)

  @@index([hotelId])
}

model RestaurantClose {
  id        String   @id @default(cuid())
  hotelId   String
  turno     String
  stage     String   @default("X")
  totals    Json
  payments  Json
  breakdown Json?
  note      String?
  createdAt DateTime @default(now())
  userId    String?

  hotel Hotel @relation(fields: [hotelId], references: [id], onDelete: Cascade)

  @@index([hotelId])
}

model RestaurantOrder {
  id               String                @id @default(cuid())
  hotelId          String
  saleNumber       String?
  saleNumberInt    Int?
  sectionId        String?
  tableId          String
  waiterId         String?
  cashierId        String?
  status           RestaurantOrderStatus @default(OPEN)
  note             String?
  covers           Int?
  serviceType      String                @default("DINE_IN")
  roomId           String?
  discountId       String?
  discountPercent  Decimal               @default(0) @db.Decimal(6, 2)
  discountAmount   Decimal               @default(0) @db.Decimal(12, 2)
  total            Decimal               @default(0) @db.Decimal(12, 2)
  tip10            Decimal               @default(0) @db.Decimal(12, 2)
  paymentBreakdown Json?
  createdAt        DateTime              @default(now())
  updatedAt        DateTime              @updatedAt

  items               RestaurantOrderItem[]
  eInvoicingDocuments EInvoicingDocument[]
  events              RestaurantOrderEvent[]
  discount            Discount?              @relation(fields: [hotelId, discountId], references: [hotelId, id])

  hotel Hotel @relation(fields: [hotelId], references: [id], onDelete: Cascade)

  @@index([hotelId])
  @@index([hotelId, tableId, status])
  @@unique([hotelId, saleNumber])
}

model RestaurantOrderItem {
  id                           String                    @id @default(cuid())
  hotelId                      String
  orderId                      String
  itemId                       String
  variantKey                   String                    @default("")
  name                         String
  category                     String?
  price                        Decimal                   @db.Decimal(12, 2)
  qty                          Int
  detailNote                   String?
  priceIncludesTaxesAndService Boolean                   @default(true)
  discountId                   String?
  discountPercent              Decimal                   @default(0) @db.Decimal(6, 2)
  area                         RestaurantKdsArea         @default(KITCHEN)
  status                       RestaurantOrderItemStatus @default(NEW)

  order    RestaurantOrder @relation(fields: [orderId], references: [id], onDelete: Cascade)
  hotel    Hotel           @relation(fields: [hotelId], references: [id], onDelete: Cascade)
  discount Discount?       @relation(fields: [hotelId, discountId], references: [hotelId, id])

  @@unique([hotelId, orderId, itemId, variantKey])
  @@index([hotelId])
}

model RestaurantOrderEvent {
  id        String   @id @default(cuid())
  hotelId   String
  orderId   String?
  eventType String
  actorId   String?
  payload   Json?
  createdAt DateTime @default(now())

  hotel Hotel            @relation(fields: [hotelId], references: [id], onDelete: Cascade)
  order RestaurantOrder? @relation(fields: [orderId], references: [id], onDelete: SetNull)

  @@index([hotelId])
  @@index([hotelId, orderId])
  @@index([hotelId, createdAt])
}

model RestaurantStaff {
  id           String              @id @default(cuid())
  hotelId      String
  launcherId   String?
  name         String
  username     String
  role         RestaurantStaffRole
  accessRoleId String?
  active       Boolean             @default(true)
  passwordHash String
  createdAt    DateTime            @default(now())
  updatedAt    DateTime            @updatedAt

  hotel      Hotel            @relation(fields: [hotelId], references: [id], onDelete: Cascade)
  launcher   LauncherAccount? @relation(fields: [launcherId], references: [id], onDelete: SetNull)
  accessRole AppRole?         @relation("RestaurantStaffAccessRole", fields: [hotelId, accessRoleId], references: [hotelId, id], onDelete: SetNull)

  @@unique([hotelId, username])
  @@index([hotelId])
  @@index([hotelId, launcherId])
}

model Discount {
  hotelId     String
  id          String
  name        String
  type        String    @default("percent")
  value       Decimal   @db.Decimal(12, 2)
  requiresPin Boolean   @default(false)
  active      Boolean   @default(true)
  expiresAt   DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  hotel                Hotel                 @relation(fields: [hotelId], references: [id], onDelete: Cascade)
  restaurantOrders     RestaurantOrder[]
  restaurantOrderItems RestaurantOrderItem[]

  @@id([hotelId, id])
  @@index([hotelId])
}

model RestaurantSection {
  id               String  @id
  hotelId          String
  name             String
  imageUrl         String?
  quickCashEnabled Boolean @default(false)

  tables          RestaurantTable[]
  objects         RestaurantSectionObject[]
  menu            RestaurantMenuItem[]
  menuAssignments RestaurantMenuAssignment[]

  hotel Hotel @relation(fields: [hotelId], references: [id], onDelete: Cascade)

  @@unique([hotelId, id])
  @@index([hotelId])
}

model RestaurantMenu {
  id        String   @id @default(cuid())
  hotelId   String
  name      String
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  items       RestaurantMenuItem[]
  entries     RestaurantMenuEntry[]
  assignments RestaurantMenuAssignment[]
  hotel       Hotel                      @relation(fields: [hotelId], references: [id], onDelete: Cascade)

  @@unique([hotelId, name])
  @@index([hotelId])
}

// Asigna un menú a una sección en un horario (sin depender del turno)
model RestaurantMenuAssignment {
  id        String   @id @default(cuid())
  hotelId   String
  sectionId String
  menuId    String
  // Bitmask: 0=Sun ... 6=Sat. Default todos los días.
  daysMask  Int      @default(127)
  // Horario local "HH:MM" (24h)
  startTime String? // null = desde inicio del día
  endTime   String? // null = hasta fin del día
  timezone  String   @default("America/Costa_Rica")
  priority  Int      @default(0)
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  section RestaurantSection @relation(fields: [sectionId], references: [id], onDelete: Cascade)
  menu    RestaurantMenu    @relation(fields: [menuId], references: [id], onDelete: Cascade)
  hotel   Hotel             @relation(fields: [hotelId], references: [id], onDelete: Cascade)

  @@index([hotelId])
  @@index([sectionId])
  @@index([menuId])
  @@index([hotelId, sectionId, active])
}

model RestaurantSectionObject {
  id        String   @id @default(cuid())
  hotelId   String
  sectionId String
  kind      String // BAR | POOL | PLANT | WALL | COUNTER | DOOR | WC | OTHER
  label     String?
  x         Float    @default(50)
  y         Float    @default(50)
  w         Float    @default(18)
  h         Float    @default(10)
  zIndex    Int      @default(0)
  rotation  Float    @default(0)
  color     String? // optional tailwind/css color hint
  meta      Json?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  section RestaurantSection @relation(fields: [sectionId], references: [id], onDelete: Cascade)
  hotel   Hotel             @relation(fields: [hotelId], references: [id], onDelete: Cascade)

  @@index([hotelId])
  @@index([sectionId])
}

model RestaurantTable {
  id        String @id
  hotelId   String
  sectionId String
  name      String
  seats     Int    @default(2)
  x         Float?
  y         Float?

  section RestaurantSection @relation(fields: [sectionId], references: [id], onDelete: Cascade)
  hotel   Hotel             @relation(fields: [hotelId], references: [id], onDelete: Cascade)

  @@index([sectionId])
  @@index([hotelId])
}

model RestaurantMenuItem {
  id        String   @id @default(cuid())
  hotelId   String
  // Compat: items antiguos atados a sectionId
  sectionId String?
  // Nuevo: items pertenecen a un menú
  menuId    String?
  name      String
  category  String?
  price     Decimal  @default(0) @db.Decimal(12, 2)
  active    Boolean  @default(true)
  createdAt DateTime @default(now())

  section RestaurantSection? @relation(fields: [sectionId], references: [id], onDelete: Cascade)
  menu    RestaurantMenu?    @relation(fields: [menuId], references: [id], onDelete: Cascade)
  hotel   Hotel              @relation(fields: [hotelId], references: [id], onDelete: Cascade)

  @@index([hotelId])
  @@index([sectionId])
  @@index([menuId])
}

// Nuevo: items de menú apuntan a Artículos (RestaurantItem)
model RestaurantMenuEntry {
  id        String   @id @default(cuid())
  hotelId   String
  menuId    String
  itemId    String // RestaurantItem.id
  active    Boolean  @default(true)
  sortOrder Int      @default(0)
  // Overrides opcionales
  category  String?
  price     Decimal? @db.Decimal(12, 2)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  menu  RestaurantMenu @relation(fields: [menuId], references: [id], onDelete: Cascade)
  item  RestaurantItem @relation(fields: [itemId], references: [id], onDelete: Cascade)
  hotel Hotel          @relation(fields: [hotelId], references: [id], onDelete: Cascade)

  @@unique([hotelId, menuId, itemId])
  @@index([hotelId])
  @@index([menuId])
  @@index([itemId])
}

model RestaurantFamily {
  id        String   @id @default(cuid())
  hotelId   String
  code      String?
  name      String
  cabys     String? // Default CABYS code for items in this family
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  hotel       Hotel                 @relation(fields: [hotelId], references: [id], onDelete: Cascade)
  subFamilies RestaurantSubFamily[]
  items       RestaurantItem[]

  @@unique([hotelId, name])
  @@unique([hotelId, code])
  @@index([hotelId])
}

model RestaurantSubFamily {
  id        String   @id @default(cuid())
  hotelId   String
  familyId  String
  code      String?
  name      String
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  hotel          Hotel                    @relation(fields: [hotelId], references: [id], onDelete: Cascade)
  family         RestaurantFamily         @relation(fields: [familyId], references: [id], onDelete: Cascade)
  subSubFamilies RestaurantSubSubFamily[]
  items          RestaurantItem[]

  @@unique([hotelId, familyId, name])
  @@unique([hotelId, familyId, code])
  @@index([hotelId])
  @@index([familyId])
}

model RestaurantSubSubFamily {
  id          String   @id @default(cuid())
  hotelId     String
  subFamilyId String
  code        String?
  name        String
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  hotel     Hotel               @relation(fields: [hotelId], references: [id], onDelete: Cascade)
  subFamily RestaurantSubFamily @relation(fields: [subFamilyId], references: [id], onDelete: Cascade)
  items     RestaurantItem[]

  @@unique([hotelId, subFamilyId, name])
  @@unique([hotelId, subFamilyId, code])
  @@index([hotelId])
  @@index([subFamilyId])
}

model RestaurantItem {
  id                           String   @id @default(cuid())
  hotelId                      String
  number                       Int
  code                         String
  name                         String
  cabys                        String?
  color                        String?
  imageUrl                     String?
  sizes                        Json?
  details                      Json?
  priceIncludesTaxesAndService Boolean  @default(true)
  price                        Decimal  @default(0) @db.Decimal(12, 2)
  tax                          Decimal  @default(0) @db.Decimal(5, 2)
  notes                        String?
  active                       Boolean  @default(true)
  familyId                     String
  subFamilyId                  String?
  subSubFamilyId               String?
  createdAt                    DateTime @default(now())
  updatedAt                    DateTime @updatedAt

  hotel        Hotel                   @relation(fields: [hotelId], references: [id], onDelete: Cascade)
  family       RestaurantFamily        @relation(fields: [familyId], references: [id], onDelete: Restrict)
  subFamily    RestaurantSubFamily?    @relation(fields: [subFamilyId], references: [id], onDelete: Restrict)
  subSubFamily RestaurantSubSubFamily? @relation(fields: [subSubFamilyId], references: [id], onDelete: Restrict)
  taxes        RestaurantItemTax[]
  recipeLines  RestaurantRecipeLine[]
  menuEntries  RestaurantMenuEntry[]

  @@unique([hotelId, code])
  @@unique([hotelId, number])
  @@index([hotelId])
  @@index([familyId])
  @@index([subFamilyId])
  @@index([subSubFamilyId])
}

model Tax {
  id        String   @id @default(cuid())
  hotelId   String
  code      String
  name      String
  percent   Decimal  @default(0) @db.Decimal(8, 4)
  scope     String   @default("room")
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  hotel Hotel               @relation(fields: [hotelId], references: [id], onDelete: Cascade)
  items RestaurantItemTax[]

  @@unique([hotelId, code])
  @@index([hotelId])
}

model RestaurantItemTax {
  id      String @id @default(cuid())
  hotelId String
  itemId  String
  taxId   String

  hotel Hotel          @relation(fields: [hotelId], references: [id], onDelete: Cascade)
  item  RestaurantItem @relation(fields: [itemId], references: [id], onDelete: Cascade)
  tax   Tax            @relation(fields: [taxId], references: [id], onDelete: Cascade)

  @@unique([hotelId, itemId, taxId])
  @@index([hotelId])
  @@index([itemId])
  @@index([taxId])
}

model HotelSequence {
  id         String   @id @default(cuid())
  hotelId    String
  key        String
  nextNumber Int      @default(1)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  hotel Hotel @relation(fields: [hotelId], references: [id], onDelete: Cascade)

  @@unique([hotelId, key])
  @@index([hotelId])
}

model RestaurantInventoryItem {
  id           String   @id @default(cuid())
  hotelId      String
  number       Int
  sku          String
  desc         String
  unit         String
  stock        Decimal  @default(0) @db.Decimal(14, 4)
  min          Decimal  @default(0) @db.Decimal(14, 4)
  cost         Decimal  @default(0) @db.Decimal(14, 4)
  taxRate      Decimal? @db.Decimal(5, 2)
  supplierName String?
  inventoryControlled Boolean @default(true)
  active       Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  hotel     Hotel                            @relation(fields: [hotelId], references: [id], onDelete: Cascade)
  movements RestaurantInventoryMovement[]
  recipes   RestaurantRecipeLine[]
  invoices  RestaurantInventoryInvoiceLine[]

  @@unique([hotelId, number])
  @@unique([hotelId, sku])
  @@index([hotelId])
}

model RestaurantInventoryInvoice {
  id           String    @id @default(cuid())
  hotelId      String
  supplierName String
  docNumber    String?
  docType      String?
  source       String    @default("MANUAL")
  issueDate    DateTime?
  currency     String?
  total        Decimal?  @db.Decimal(14, 4)
  taxTotal     Decimal?  @db.Decimal(14, 4)
  externalKey  String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  hotel Hotel                            @relation(fields: [hotelId], references: [id], onDelete: Cascade)
  lines RestaurantInventoryInvoiceLine[]

  @@index([hotelId])
}

model RestaurantInventoryInvoiceLine {
  id              String   @id @default(cuid())
  hotelId         String
  invoiceId       String
  inventoryItemId String
  name            String
  qty             Decimal  @db.Decimal(14, 4)
  unit            String
  cost            Decimal  @db.Decimal(14, 4)
  taxRate         Decimal? @db.Decimal(5, 2)
  taxAmount       Decimal? @db.Decimal(14, 4)
  lineTotal       Decimal? @db.Decimal(14, 4)
  createdAt       DateTime @default(now())

  hotel         Hotel                      @relation(fields: [hotelId], references: [id], onDelete: Cascade)
  invoice       RestaurantInventoryInvoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  inventoryItem RestaurantInventoryItem    @relation(fields: [inventoryItemId], references: [id], onDelete: Restrict)

  @@index([hotelId])
  @@index([invoiceId])
  @@index([inventoryItemId])
}

model RestaurantInventoryMovement {
  id        String   @id @default(cuid())
  hotelId   String
  itemId    String
  qtyDelta  Decimal  @db.Decimal(14, 4) // + adds stock, - consumes stock
  reason    String?
  refType   String?
  refId     String?
  createdBy String?
  createdAt DateTime @default(now())

  item  RestaurantInventoryItem @relation(fields: [itemId], references: [id], onDelete: Cascade)
  hotel Hotel                   @relation(fields: [hotelId], references: [id], onDelete: Cascade)

  @@index([hotelId])
  @@index([itemId])
  @@index([hotelId, refType, refId])
}

model RestaurantRecipeLine {
  id               String   @id @default(cuid())
  hotelId          String
  restaurantItemId String
  inventoryItemId  String
  qty              Decimal  @db.Decimal(14, 4) // stored in inventory item unit
  note             String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  hotel          Hotel                   @relation(fields: [hotelId], references: [id], onDelete: Cascade)
  restaurantItem RestaurantItem          @relation(fields: [restaurantItemId], references: [id], onDelete: Cascade)
  inventoryItem  RestaurantInventoryItem @relation(fields: [inventoryItemId], references: [id], onDelete: Cascade)

  @@unique([hotelId, restaurantItemId, inventoryItemId])
  @@index([hotelId])
  @@index([restaurantItemId])
  @@index([inventoryItemId])
}

// ⬇️ NUEVO
model SaasClient {
  id          String   @id @default(cuid())
  name        String
  companyId   String?
  email       String?
  phone1      String?
  phone2      String?
  ownerName   String?
  managerName String?
  managerId   String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  hotels Hotel[]
}

model SaasBillingPayment {
  id        String   @id @default(cuid())
  hotelId   String
  amount    Decimal  @default(0) @db.Decimal(12, 2)
  currency  String   @default("USD")
  paidAt    DateTime
  note      String?
  createdAt DateTime @default(now())

  hotel Hotel @relation(fields: [hotelId], references: [id], onDelete: Cascade)

  @@index([hotelId])
  @@index([hotelId, paidAt])
}

model SaasConfig {
  key              String   @id
  smtp             Json?
  printFormsGlobal Json?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

model Hotel {
  id                   String   @id @default(cuid())
  number               Int      @unique @default(autoincrement())
  name                 String
  membership           String   @default("PLATINUM")
  membershipMonthlyFee Decimal  @default(0) @db.Decimal(12, 2)
  currency             String   @default("CRC")
  phone1               String?
  phone2               String?
  ownerName            String?
  managerName          String?
  companyId            String?
  managerId            String?
  clientId             String?
  fxBuy                Decimal  @default(0) @db.Decimal(12, 4)
  fxSell               Decimal  @default(0) @db.Decimal(12, 4)
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  rooms                           Room[]
  roomTypes                       RoomType[]
  reservations                    Reservation[]
  users                           User[]
  roles                           AppRole[]
  rolePerms                       RolePermission[]
  invoices                        Invoice[]
  guests                          Guest[]
  payments                        Payment[]
  auditLogs                       AuditLog[]
  invoiceItems                    InvoiceItem[]
  advanceDeposits                 AdvanceDeposit[]
  creditNotes                     CreditNote[]
  cashAudits                      CashAudit[]
  restaurantConfig                RestaurantConfig?
  restaurantPrintJobs             RestaurantPrintJob[]
  restaurantCloses                RestaurantClose[]
  restaurantOrders                RestaurantOrder[]
  restaurantOrderItems            RestaurantOrderItem[]
  restaurantOrderEvents           RestaurantOrderEvent[]
  restaurantSections              RestaurantSection[]
  restaurantTables                RestaurantTable[]
  restaurantMenuItems             RestaurantMenuItem[]
  restaurantMenus                 RestaurantMenu[]
  restaurantMenuAssignments       RestaurantMenuAssignment[]
  restaurantMenuEntries           RestaurantMenuEntry[]
  restaurantFamilies              RestaurantFamily[]
  restaurantSubFamilies           RestaurantSubFamily[]
  restaurantSubSubFamilies        RestaurantSubSubFamily[]
  restaurantItems                 RestaurantItem[]
  taxes                           Tax[]
  restaurantItemTaxes             RestaurantItemTax[]
  restaurantInventoryItems        RestaurantInventoryItem[]
  restaurantInventoryMovements    RestaurantInventoryMovement[]
  restaurantInventoryInvoices     RestaurantInventoryInvoice[]
  restaurantInventoryInvoiceLines RestaurantInventoryInvoiceLine[]
  restaurantRecipeLines           RestaurantRecipeLine[]
  restaurantStaff                 RestaurantStaff[]
  discounts                       Discount[]
  reservationSequences            ReservationSequence[]
  hotelSequences                  HotelSequence[]
  launcherAccounts                LauncherAccount[]
  ratePlans                       RatePlan[]
  mealPlans                       MealPlan[]
  contracts                       Contract[]
  roomDays                        RoomDay[]
  eInvoicingConfig                EInvoicingConfig?
  eInvoicingRequirements          EInvoicingRequirement[]
  eInvoicingSequences             EInvoicingSequence[]
  eInvoicingDocuments             EInvoicingDocument[]
  eInvoicingAcknowledgements      EInvoicingAcknowledgement[]
  cabysCodes                      CabysCode[]
  eInvoicingCatalogEntries        EInvoicingCatalogEntry[]
  RestaurantSectionObject         RestaurantSectionObject[]
  saasClient                      SaasClient?                      @relation(fields: [clientId], references: [id], onDelete: SetNull)
  saasBillingPayments             SaasBillingPayment[]
}

model EInvoicingConfig {
  hotelId     String   @id
  version     String   @default("CR-4.4")
  enabled     Boolean  @default(false)
  provider    String   @default("hacienda-cr")
  environment String   @default("sandbox") // sandbox | production
  credentials Json?
  settings    Json?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  hotel Hotel @relation(fields: [hotelId], references: [id], onDelete: Cascade)
}

model EInvoicingRequirement {
  id          String   @id @default(cuid())
  hotelId     String
  version     String   @default("CR-4.4")
  code        String
  category    String
  title       String
  description String
  required    Boolean  @default(true)
  status      String   @default("PENDING") // PENDING | IN_PROGRESS | DONE | NOT_APPLICABLE
  notes       String?
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  hotel Hotel @relation(fields: [hotelId], references: [id], onDelete: Cascade)

  @@unique([hotelId, code])
  @@index([hotelId])
}

model EInvoicingSequence {
  id         String            @id @default(cuid())
  hotelId    String
  docType    EInvoicingDocType
  branch     String            @default("001") // 3 digits
  terminal   String            @default("00001") // 5 digits
  nextNumber Int               @default(1) // 1..N (10 digits in consecutive)
  createdAt  DateTime          @default(now())
  updatedAt  DateTime          @updatedAt

  hotel Hotel @relation(fields: [hotelId], references: [id], onDelete: Cascade)

  @@unique([hotelId, docType, branch, terminal])
  @@index([hotelId])
}

model EInvoicingDocument {
  id                String                      @id @default(cuid())
  hotelId           String
  invoiceId         String?
  restaurantOrderId String?
  docType           EInvoicingDocType
  status            EInvoicingDocStatus         @default(DRAFT)
  branch            String                      @default("001")
  terminal          String                      @default("00001")
  consecutive       String?
  key               String?
  receiver          Json?
  payload           Json?
  xmlSigned         String?
  response          Json?
  acknowledgements  EInvoicingAcknowledgement[]
  createdAt         DateTime                    @default(now())
  updatedAt         DateTime                    @updatedAt

  invoice         Invoice?         @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  restaurantOrder RestaurantOrder? @relation(fields: [restaurantOrderId], references: [id], onDelete: Cascade)
  hotel           Hotel            @relation(fields: [hotelId], references: [id], onDelete: Cascade)

  @@unique([hotelId, invoiceId, docType])
  @@unique([hotelId, restaurantOrderId, docType])
  @@index([hotelId])
  @@index([invoiceId])
  @@index([restaurantOrderId])
}

model EInvoicingAcknowledgement {
  id         String              @id @default(cuid())
  hotelId    String
  documentId String
  type       EInvoicingAckType
  status     EInvoicingAckStatus @default(RECEIVED)
  message    String?
  payload    Json?
  createdAt  DateTime            @default(now())

  document EInvoicingDocument @relation(fields: [documentId], references: [id], onDelete: Cascade)
  hotel    Hotel              @relation(fields: [hotelId], references: [id], onDelete: Cascade)

  @@index([hotelId])
  @@index([documentId])
}

model ReservationSequence {
  hotelId    String @id
  nextNumber Int    @default(1)

  hotel Hotel @relation(fields: [hotelId], references: [id], onDelete: Cascade)
}

// Usuarios de launcher (acceso previo por hotel, independientes de User)
model LauncherAccount {
  id        String   @id @default(cuid())
  username  String // identificador de usuario (login) ─ unico por hotel
  name      String   @default("") // nombre visible
  password  String
  hotelId   String
  roleId    String   @default("ADMIN")
  createdAt DateTime @default(now())

  hotel           Hotel             @relation(fields: [hotelId], references: [id], onDelete: Cascade)
  role            AppRole           @relation(fields: [hotelId, roleId], references: [hotelId, id], onDelete: Cascade)
  restaurantStaff RestaurantStaff[]

  @@unique([hotelId, username])
  @@index([hotelId])
  @@index([hotelId, roleId])
  @@map("UserLauncher")
}

// ===== Models =====
model User {
  id           String        @id @default(cuid())
  email        String        @unique
  name         String?
  password     String
  role         Role          @default(RECEPTION)
  hotelId      String
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  reservations Reservation[]

  hotel Hotel @relation(fields: [hotelId], references: [id], onDelete: Cascade)

  @@index([hotelId])
}

model Guest {
  id               String           @id @default(cuid())
  firstName        String
  lastName         String
  email            String?
  phone            String?
  state            String?
  idType           String?
  idNumber         String?
  legalName        String?
  managerName      String?
  economicActivity String?
  emailAlt1        String?
  emailAlt2        String?
  country          String?
  city             String?
  address          String?
  company          String?
  notes            String?
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt
  reservations     Reservation[]
  invoices         Invoice[]
  advanceDeposits  AdvanceDeposit[]
  creditNotes      CreditNote[]
  hotelId          String
  hotel            Hotel            @relation(fields: [hotelId], references: [id], onDelete: Cascade)

  @@unique([hotelId, email])
  @@index([hotelId])
}

model Room {
  id        String     @id @default(cuid())
  number    String
  type      String
  status    RoomStatus @default(AVAILABLE)
  archived  Boolean    @default(false)
  notes     String?
  baseRate  Decimal    @default(0) @db.Decimal(10, 2)
  currency  String     @default("CRC")
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  hotelId String
  hotel   Hotel  @relation(fields: [hotelId], references: [id], onDelete: Cascade)

  reservations Reservation[]
  days         RoomDay[]

  @@unique([hotelId, number])
  @@index([hotelId])
}

model RoomType {
  id        String   @id
  name      String
  beds      String?
  hotelId   String
  hotel     Hotel    @relation(fields: [hotelId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([hotelId, id])
  @@index([hotelId])
}

model Reservation {
  id         String            @id @default(cuid())
  code       String            @unique
  rooming    String?
  otaCode    String?
  roomId     String
  guestId    String
  userId     String?
  contractId String?
  ratePlanId String?
  mealPlanId String?
  checkIn    DateTime
  checkOut   DateTime
  adults     Int               @default(2)
  children   Int               @default(0)
  status     ReservationStatus @default(CONFIRMED)
  source     BookingSource?
  createdAt  DateTime          @default(now())
  updatedAt  DateTime          @updatedAt
  auditTrail Json?

  room     Room      @relation(fields: [roomId], references: [id])
  guest    Guest     @relation(fields: [guestId], references: [id])
  user     User?     @relation(fields: [userId], references: [id])
  contract Contract? @relation("ContractReservations", fields: [hotelId, contractId], references: [hotelId, id], onDelete: SetNull)
  ratePlan RatePlan? @relation("RatePlanReservations", fields: [hotelId, ratePlanId], references: [hotelId, id], onDelete: SetNull)
  mealPlan MealPlan? @relation("MealPlanReservations", fields: [hotelId, mealPlanId], references: [hotelId, id], onDelete: SetNull)

  /// Relación 1–1 con Invoice (lado SIN FK)
  invoice         Invoice?         @relation("ReservationInvoice")
  advanceDeposits AdvanceDeposit[]

  days RoomDay[]

  hotelId String
  hotel   Hotel  @relation(fields: [hotelId], references: [id], onDelete: Cascade)

  @@index([roomId])
  @@index([guestId])
  @@index([hotelId])
}

model RatePlan {
  id           String    @default(cuid())
  name         String
  currency     String    @default("CRC")
  price        Decimal   @default(0) @db.Decimal(12, 2)
  derived      Boolean   @default(false)
  dateFrom     DateTime?
  dateTo       DateTime?
  restrictions Json?
  active       Boolean   @default(true)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  hotelId      String
  hotel        Hotel         @relation(fields: [hotelId], references: [id], onDelete: Cascade)
  reservations Reservation[] @relation("RatePlanReservations")

  @@id([hotelId, id])
  @@index([hotelId])
}

model MealPlan {
  id        String
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  hotelId      String
  hotel        Hotel         @relation(fields: [hotelId], references: [id], onDelete: Cascade)
  reservations Reservation[] @relation("MealPlanReservations")

  @@id([hotelId, id])
  @@index([hotelId])
}

model Contract {
  id         String
  channel    String
  commission Decimal  @default(0) @db.Decimal(6, 4)
  active     Boolean  @default(true)
  ratePlans  Json?
  mealPlanId String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  hotelId      String
  hotel        Hotel         @relation(fields: [hotelId], references: [id], onDelete: Cascade)
  reservations Reservation[] @relation("ContractReservations")

  @@id([hotelId, id])
  @@index([hotelId])
}

model RoomDay {
  id            String   @id @default(cuid())
  date          DateTime
  roomId        String
  reservationId String?
  hotelId       String

  status RoomStatus @default(AVAILABLE)
  rate   Decimal    @default(0) @db.Decimal(12, 2)
  notes  String?

  room        Room         @relation(fields: [roomId], references: [id])
  reservation Reservation? @relation(fields: [reservationId], references: [id], onDelete: SetNull)
  hotel       Hotel        @relation(fields: [hotelId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([hotelId, roomId, date])
  @@index([reservationId])
  @@index([hotelId])
}

model AuditLog {
  id        String   @id @default(cuid())
  actorId   String?
  action    String
  entity    String
  entityId  String
  reason    String?
  payload   Json?
  createdAt DateTime @default(now())
  hotelId   String
  hotel     Hotel    @relation(fields: [hotelId], references: [id], onDelete: Cascade)

  @@index([hotelId])
}

model Country {
  code    String   @id
  name    String
  regions Region[]
  cities  City[]
}

model Region {
  id          String  @id @default(cuid())
  code        String?
  name        String
  countryCode String
  country     Country @relation(fields: [countryCode], references: [code], onDelete: Cascade)
  cities      City[]

  @@index([countryCode])
}

model City {
  id          String  @id @default(cuid())
  name        String
  countryCode String
  regionId    String?
  country     Country @relation(fields: [countryCode], references: [code], onDelete: Cascade)
  region      Region? @relation(fields: [regionId], references: [id], onDelete: SetNull)

  @@index([countryCode])
  @@index([regionId])
}

model Invoice {
  id            String        @id @default(cuid())
  number        String        @unique
  reservationId String        @unique
  guestId       String
  total         Decimal       @default(0) @db.Decimal(12, 2)
  currency      String        @default("CRC")
  status        InvoiceStatus @default(DRAFT)
  eInvoice      Json?
  auditTrail    Json?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  hotelId       String

  /// Lado CON FK (1–1). Todo en una línea para evitar parseos raros:
  reservation         Reservation          @relation("ReservationInvoice", fields: [reservationId], references: [id], onDelete: Cascade)
  guest               Guest                @relation(fields: [guestId], references: [id])
  items               InvoiceItem[]
  payments            Payment[]
  creditNotes         CreditNote[]
  eInvoicingDocuments EInvoicingDocument[]
  hotel               Hotel                @relation(fields: [hotelId], references: [id], onDelete: Cascade)

  @@index([guestId])
  @@index([hotelId])
}

model InvoiceItem {
  id          String   @id @default(cuid())
  invoiceId   String
  description String
  quantity    Int      @default(1)
  unitPrice   Decimal  @default(0) @db.Decimal(12, 2)
  total       Decimal  @default(0) @db.Decimal(12, 2)
  createdAt   DateTime @default(now())
  hotelId     String

  invoice Invoice @relation(fields: [invoiceId], references: [id])
  hotel   Hotel   @relation(fields: [hotelId], references: [id], onDelete: Cascade)

  @@index([invoiceId])
  @@index([hotelId])
}

model Payment {
  id        String   @id @default(cuid())
  invoiceId String
  method    String
  amount    Decimal  @default(0) @db.Decimal(12, 2)
  createdAt DateTime @default(now())
  hotelId   String

  invoice Invoice @relation(fields: [invoiceId], references: [id])
  hotel   Hotel   @relation(fields: [hotelId], references: [id], onDelete: Cascade)

  @@index([invoiceId])
  @@index([hotelId])
}

model AdvanceDeposit {
  id             String   @id @default(cuid())
  reservationId  String?
  guestId        String?
  amount         Decimal  @default(0) @db.Decimal(12, 2)
  currency       String   @default("CRC")
  note           String?
  appliedInvoice String?
  createdAt      DateTime @default(now())
  hotelId        String

  reservation Reservation? @relation(fields: [reservationId], references: [id])
  guest       Guest?       @relation(fields: [guestId], references: [id])
  hotel       Hotel        @relation(fields: [hotelId], references: [id], onDelete: Cascade)

  @@index([hotelId])
  @@index([reservationId])
  @@index([guestId])
}

model CreditNote {
  id        String   @id @default(cuid())
  invoiceId String?
  guestId   String?
  amount    Decimal  @default(0) @db.Decimal(12, 2)
  currency  String   @default("CRC")
  reason    String?
  createdAt DateTime @default(now())
  hotelId   String

  invoice Invoice? @relation(fields: [invoiceId], references: [id])
  guest   Guest?   @relation(fields: [guestId], references: [id])
  hotel   Hotel    @relation(fields: [hotelId], references: [id], onDelete: Cascade)

  @@index([hotelId])
  @@index([invoiceId])
  @@index([guestId])
}

model CashAudit {
  id          String          @id @default(cuid())
  hotelId     String
  module      CashAuditModule
  openedAt    DateTime?
  closedAt    DateTime?       @default(now())
  totals      Json?
  details     Json?
  note        String?
  createdById String?
  createdAt   DateTime        @default(now())

  hotel Hotel @relation(fields: [hotelId], references: [id], onDelete: Cascade)

  @@index([hotelId])
  @@index([hotelId, module, createdAt])
}

model CabysCode {
  id          String   @id // CABYS code
  description String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  hotelId     String

  hotel Hotel @relation(fields: [hotelId], references: [id], onDelete: Cascade)

  @@index([hotelId])
  @@index([hotelId, description])
}

model EInvoicingCatalogEntry {
  id        String   @id @default(cuid())
  hotelId   String
  catalog   String
  code      String
  label     String
  version   String?
  extra     Json?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  hotel Hotel @relation(fields: [hotelId], references: [id], onDelete: Cascade)

  @@unique([hotelId, catalog, code])
  @@index([hotelId, catalog])
  @@index([hotelId, code])
}

model AppRole {
  id          String
  name        String
  description String?
  hotelId     String

  hotel            Hotel             @relation(fields: [hotelId], references: [id], onDelete: Cascade)
  permissions      RolePermission[]
  launcherAccounts LauncherAccount[]
  restaurantStaff  RestaurantStaff[] @relation("RestaurantStaffAccessRole")

  @@id([hotelId, id])
  @@index([hotelId])
}

model Permission {
  id          String           @id
  description String?
  permissions RolePermission[]
}

model RolePermission {
  id           String @id @default(cuid())
  roleId       String
  permissionId String
  hotelId      String

  role       AppRole    @relation(fields: [roleId, hotelId], references: [id, hotelId], onDelete: Cascade)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)
  hotel      Hotel      @relation(fields: [hotelId], references: [id], onDelete: Cascade)

  @@unique([hotelId, roleId, permissionId])
  @@index([hotelId])
}
